{
    "name": "datalumo/laravel",
    "description": "Laravel integration for Datalumo - Scout-inspired searchable models",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "datalumo/php-sdk": "@dev",
        "illuminate/bus": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Datalumo\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Datalumo\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Datalumo\\Laravel\\DatalumoServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../php-sdk"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
